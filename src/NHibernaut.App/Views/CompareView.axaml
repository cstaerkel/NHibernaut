<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NHibernaut.App.ViewModels"
             xmlns:conv="clr-namespace:NHibernaut.App.Converters"
             x:DataType="vm:CompareViewModel"
             x:Class="NHibernaut.App.Views.CompareView">
  <ScrollViewer>
    <StackPanel Spacing="12" Margin="8">
      <!-- Session selectors -->
      <Grid ColumnDefinitions="*,16,*">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Session A" FontSize="11" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding Options}"
                    SelectedItem="{Binding SelectedA}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:SessionItemViewModel">
                <TextBlock Text="{Binding CompareLabel}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="4">
          <TextBlock Text="Session B" FontSize="11" Opacity="0.7" />
          <ComboBox ItemsSource="{Binding Options}"
                    SelectedItem="{Binding SelectedB}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:SessionItemViewModel">
                <TextBlock Text="{Binding CompareLabel}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
      </Grid>

      <!-- Metrics table -->
      <StackPanel Spacing="0">
        <!-- Header -->
        <Grid ColumnDefinitions="*,100,100,100" Margin="0,0,0,4">
          <TextBlock Grid.Column="0" Text="Metric" FontSize="11" Opacity="0.7" FontWeight="SemiBold" />
          <TextBlock Grid.Column="1" Text="A" FontSize="11" Opacity="0.7" FontWeight="SemiBold" HorizontalAlignment="Right" />
          <TextBlock Grid.Column="2" Text="B" FontSize="11" Opacity="0.7" FontWeight="SemiBold" HorizontalAlignment="Right" />
          <TextBlock Grid.Column="3" Text="Delta" FontSize="11" Opacity="0.7" FontWeight="SemiBold" HorizontalAlignment="Right" />
        </Grid>
        <!-- Rows -->
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:CompareRow">
              <Grid ColumnDefinitions="*,100,100,100" Margin="0,2">
                <TextBlock Grid.Column="0" Text="{Binding Metric}" FontSize="11" />
                <TextBlock Grid.Column="1" Text="{Binding ADisplay}" FontSize="11" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="2" Text="{Binding BDisplay}" FontSize="11" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3"
                           Text="{Binding DeltaDisplay}"
                           FontSize="11"
                           HorizontalAlignment="Right"
                           Foreground="{Binding State, Converter={x:Static conv:DiffStateToBrushConverter.Instance}}" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
