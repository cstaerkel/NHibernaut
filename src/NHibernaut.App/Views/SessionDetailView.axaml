<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NHibernaut.App.ViewModels"
             xmlns:conv="clr-namespace:NHibernaut.App.Converters"
             x:DataType="vm:SessionDetailViewModel"
             x:Class="NHibernaut.App.Views.SessionDetailView"
             x:Name="Root">
  <Grid RowDefinitions="*,Auto">
  <ScrollViewer Grid.Row="0">
    <StackPanel Spacing="8" Margin="4">

      <!-- Title -->
      <TextBlock Text="{Binding Title}"
                 FontFamily="Cascadia Code,Consolas,monospace"
                 FontWeight="Bold"
                 FontSize="13" />

      <!-- Alerts -->
      <ItemsControl ItemsSource="{Binding Alerts}"
                    IsVisible="{Binding Alerts.Count, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:AlertViewModel">
            <Button Margin="0,2"
                    Padding="8,4"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="{Binding Severity, Converter={x:Static conv:SeverityToBrushConverter.Instance}}"
                    Command="{Binding #Root.((vm:SessionDetailViewModel)DataContext).HighlightAlertCommand}"
                    CommandParameter="{Binding}">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" />
                <TextBlock Text="{Binding Suggestion}" TextWrapping="Wrap" FontSize="11" Opacity="0.8"
                           IsVisible="{Binding Suggestion, Converter={x:Static conv:NullToCollapsedConverter.Instance}}" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Waterfall -->
      <TextBlock Text="Waterfall" FontSize="11" Opacity="0.6" Margin="0,4,0,0"
                 IsVisible="{Binding Bars.Count, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}" />
      <ItemsControl ItemsSource="{Binding Bars}"
                    IsVisible="{Binding Bars.Count, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:WaterfallBarViewModel">
            <Grid Height="14" Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LeftStar}" />
                <ColumnDefinition Width="{Binding WidthStar}" />
                <ColumnDefinition Width="{Binding RightStar}" />
              </Grid.ColumnDefinitions>
              <Button Grid.Column="1"
                      Padding="0"
                      Background="{Binding ColorKey, Converter={x:Static conv:KindToBrushConverter.Instance}}"
                      BorderBrush="White"
                      BorderThickness="{Binding IsHighlighted, Converter={x:Static conv:HighlightToThicknessConverter.Instance}}"
                      ToolTip.Tip="{Binding Tooltip}"
                      Command="{Binding #Root.((vm:SessionDetailViewModel)DataContext).SelectStatementCommand}"
                      CommandParameter="{Binding StatementId}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Statement groups -->
      <TextBlock Text="Statements" FontSize="11" Opacity="0.6" Margin="0,4,0,0"
                 IsVisible="{Binding Groups.Count, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}" />
      <ItemsControl ItemsSource="{Binding Groups}"
                    IsVisible="{Binding Groups.Count, Converter={x:Static conv:PositiveToVisibleConverter.Instance}}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:StatementGroupViewModel">
            <StackPanel>
              <!-- Group header: ToggleButton collapses/expands groups; single items render only as the inner row -->
              <ToggleButton IsChecked="{Binding IsFolded, Mode=TwoWay}"
                            IsVisible="{Binding IsGroup}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="4,2"
                            Margin="0,1">
                <TextBlock Text="{Binding Header}"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis" />
              </ToggleButton>
              <!-- Items inside the group — visible for single items always, for groups only when unfolded -->
              <ItemsControl ItemsSource="{Binding Items}"
                            IsVisible="{Binding ShowItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:StatementViewModel">
                    <Button Padding="4,2"
                            Margin="12,1,0,1"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Command="{Binding #Root.((vm:SessionDetailViewModel)DataContext).SelectStatementCommand}"
                            CommandParameter="{Binding Id}">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SqlFirstLine}"
                                   FontFamily="Cascadia Code,Consolas,monospace"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DurationMs, StringFormat='{}{0:F0} ms'}"
                                   FontSize="11"
                                   Margin="8,0,0,0"
                                   Foreground="{Binding IsSlow, Converter={x:Static conv:SlowToBrushConverter.Instance}}" />
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>

  <!-- Statement detail panel — appears below the list when a statement is selected -->
  <Border Grid.Row="1"
          BorderThickness="0,1,0,0"
          BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
          MaxHeight="320"
          IsVisible="{Binding StatementPanel, Converter={x:Static conv:NullToCollapsedConverter.Instance}}">
    <ContentControl Content="{Binding StatementPanel}" />
  </Border>

  </Grid>
</UserControl>
