<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="NHibernaut"
           Manufacturer="NHibernaut contributors"
           Version="$(var.Version)"
           UpgradeCode="927B0E28-A43F-4CCD-9B91-2460538B0374"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of NHibernaut is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- SourceFile is resolved relative to the `wix build` working directory (repo root in CI),
         not to this .wxs file. The icon lives in the App source tree, not the published output. -->
    <Icon Id="AppIcon.ico" SourceFile="src\NHibernaut.App\Assets\nhibernaut-app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="NHibernaut" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="NHibernaut" />
    </StandardDirectory>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <Component Id="AppShortcut" Directory="AppShortcutFolder" Bitness="always64">
      <Shortcut Id="AppStartMenuShortcut"
                Name="NHibernaut"
                Target="[INSTALLFOLDER]nhibernaut-app.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\NHibernaut\App" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="NHibernaut" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppShortcut" />
    </Feature>
  </Package>
</Wix>
