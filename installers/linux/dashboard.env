# NHibernaut Dashboard configuration. Restart after editing:
#   sudo systemctl restart nhibernaut-dashboard
NHIBERNAUT_BIND=0.0.0.0
NHIBERNAUT_PORT=5005
# REQUIRED when NHIBERNAUT_BIND is non-loopback. If left empty the service
# generates one on start and logs it (journalctl -u nhibernaut-dashboard).
NHIBERNAUT_AUTH_TOKEN=
